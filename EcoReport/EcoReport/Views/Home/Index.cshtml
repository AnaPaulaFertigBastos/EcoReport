@model List<TipoDeArea>

@{
    ViewData["Title"] = "Home Page";
    // var tiposDeArea = (List<TipoDeArea>)ViewData["TiposDeArea"];
}

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <div id="map" style="height:500px;"></div>

    <div id="cadastro-modal" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="modal-novo-ponto">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="form-ponto" name="FormPonto" enctype="multipart/form-data">
                   
                    <div class="modal-header">
                        <h4 class="modal-title" id="modal-novo-ponto">Ponto selecionado</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
                    </div>
                    <div class="modal-body d-flex flex-column text-start gap-3">
                        <div id="container-erro" class="alert alert-danger align-items-center display-none-imp" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div id="mensagem-erro"></div>
                        </div>
                        <input type="hidden" id="lat" name="Lat" value="" />
                        <input type="hidden" id="lon" name="Lon" value="" />
                        <div class="form-group d-flex flex-column gap-2">
                            <label class="control-label">Descrição: *</label>
                            <input name="Descricao" type="text" class="form-control" required/>
                        </div>
                        <div class="form-group d-flex flex-column gap-1">
                            <label class="control-label">Classificação: *</label>
                            
                                @foreach (var tipo in Model ) {
                                
                                    <div class="form-check">
                                        <input 
                                            type="checkbox" 
                                            class="form-check-input"
                                            name="Tipos[]" 
                                            value="@tipo.Id" />

                                        <label class="form-check-label">
                                            @tipo.Classificacao
                                        </label>
                                    </div>
                                
                                }
                                <div class="form-check">
                                    <input type="checkbox"
                                           class="form-check-input"
                                           name="OutroTipo"
                                           id="check-outro-tipo"
                                           value="0" />

                                    <label class="form-check-label">
                                        Outro
                                    </label>
                                </div>
                                <div class="form-group">
                                    
                                    <input type="text" name="OutraClassificacao" value="" id="input-outro-tipo" class="form-control display-none-imp" placeholder="Escreva..." />
                                </div>
                                
                            
                        </div>

                        <div class="form-group d-flex flex-column gap-2 no-margin">
                            <label class="control-label">Foto:</label>
                            <input name="Arquivo" type="file" class="form-control" />
                        </div>
                        
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-success">Enviar</button>
                    </div>
                </form>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->
    </div><!-- /.modal cadastro -->

    <div id="visualizar-ponto" class="modal fade" tabindex="-1" role="dialog" aria-labelledby="modal-visualizar-ponto">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="form-alterar-status" name="formAlterarStatus">
                    <div class="modal-header">
                        <h4 class="modal-title" id="modal-novo-ponto">Visualizar Ponto</h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
                    </div>
                    <div class="modal-body d-flex flex-column text-start gap-3">
                        <div class="form-group d-flex flex-column gap-2">
                            <label class="control-label">Descrição: </label>
                            <input type="text" id="descricao-readonly" name="descricaoReadonly" class="form-control" value="" readonly />
                        </div>
                        <div class="form-group d-flex flex-column gap-2">
                            <p class="control-label no-margin">Classificações:</p>
                            <div id="classificacoes-readonly">

                            </div>
                        </div>

                        <div class="form-group d-flex flex-column gap-2 display-none-imp" id="div-img-readonly">
                            <p class="control-label no-margin">Foto:</p>
                            <div id="div-img-point" class="d-flex justify-content-center align-items-center">
                                <img src="#" alt="Imagem anexada ao ponto" />
                            </div>
                        
                        </div>
                        <input type="hidden" name="idPonto" value="" id="id-ponto" />
                        <div class="form-group d-flex flex-column gap-2">
                        
                            <div class="d-flex flex-row gap-3">
                                <p class="control-label no-margin">Resolvido:</p>
                                <div class="form-check form-switch d-flex no-margin">
                                    <input class="form-check-input" type="checkbox" id="status-switch" name="resolvido">
                                    <label class="form-check-label ms-2" for="statusSwitch" id="status-label">
                                        Não
                                    </label>
                                </div>
                            </div>
                            <div class="d-flex align-items-center text-danger small">
                                <i class="bi bi-info-circle me-2"></i>
                                <p class="no-margin">Ao marcar como resolvido, esse ponto não aparecerá mais no mapa.</p>
                            </div>
                        
                        </div>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Salvar mudança</button>
                    </div>
                </form>
            </div><!-- /.modal-content -->
        </div><!-- /.modal-dialog -->
    </div><!-- /.modal visualizar -->
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>
